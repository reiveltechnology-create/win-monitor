# =====================================================
# WIN MONITOR - Variáveis de Ambiente
# =====================================================
# Esta versão usa fontes públicas gratuitas (ForexFactory),
# então NÃO é necessária chave de API.
# =====================================================

# Servidor
PORT=3030

# Janela de polling padrão (em segundos)
POLL_INTERVAL_SEC=60

# Polling rápido (em segundos) - usado perto de eventos
POLL_FAST_SEC=5

# Antecedência para anunciar evento iminente (minutos antes)
ANNOUNCE_AHEAD_MIN=5

# Autenticação HTTP Basic (obrigatório em produção)
AUTH_USER=
AUTH_PASS=

# Anthropic Claude API — chave para gerar análises institucionais pós-release
# Obtenha em https://console.anthropic.com/settings/keys
# Custo aproximado: R$ 0,10 a R$ 0,15 por análise (Claude Sonnet 4.6)
ANTHROPIC_API_KEY=

# Mantido por compatibilidade — não usado nesta versão (fontes gratuitas)
TE_API_KEY=
