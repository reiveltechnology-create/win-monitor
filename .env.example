# =====================================================
# TradingEconomics API
# =====================================================
# Pegue uma chave gratuita em https://tradingeconomics.com/api/
# A chave 'guest:guest' funciona com dados limitados pra testes.
TE_API_KEY=guest:guest

# =====================================================
# Servidor
# =====================================================
PORT=3030

# Janela de polling padrão (em segundos) - quando não há evento iminente
POLL_INTERVAL_SEC=60

# Polling rápido (em segundos) - usado quando há evento nos próximos 30min ou logo após release
POLL_FAST_SEC=5

# Antecedência para anunciar evento iminente (minutos antes da hora)
ANNOUNCE_AHEAD_MIN=5

# =====================================================
# Autenticação (PRODUÇÃO - obrigatório se acessível pela internet)
# =====================================================
# Deixe vazio para desabilitar (modo dev/local).
# Em produção (VPS), DEFINA usuário e senha forte.
AUTH_USER=
AUTH_PASS=
